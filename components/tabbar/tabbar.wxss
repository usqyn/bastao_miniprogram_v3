.tabbar{position:fixed;bottom:0;left:0;right:0;height:120rpx;background:#fff;display:flex;box-shadow:0 -4rpx 20rpx rgba(0,0,0,.08);z-index:999}.tab-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding-top:16rpx}.tab-item .icon{font-size:40rpx;margin-bottom:6rpx}.tab-item .text{font-size:22rpx;color:#667085}.tab-item.active .text{color:#003D7A;font-weight:600}