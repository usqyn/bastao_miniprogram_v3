/* 底部导航栏 */
.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 12rpx;
  transition: all 0.3s ease;
}

/* 图标样式 */
.tab-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 4rpx;
  transition: all 0.3s ease;
  opacity: 0.5;
  filter: grayscale(30%);
}

/* 选中状态 */
.tab-item.active .tab-icon {
  opacity: 1;
  filter: grayscale(0%);
  transform: scale(1.1) translateY(-4rpx);
}

/* 文字样式 */
.tab-item .text {
  font-size: 20rpx;
  color: #999;
  transition: all 0.3s ease;
}

.tab-item.active .text {
  color: #003D7A;
  font-weight: 600;
}
