@font-face {
  font-family: 'KazakhArabicLight';
  src: url('https://raw.githubusercontent.com/nick-zh/arabic-font/main/fonts/NotoSansArabic-Light.ttf') format('truetype');
}
page{background:#F6F8FB;color:#1A1A1A;font-family:-apple-system,BlinkMacSystemFont,'Noto Sans SC','Noto Sans Arabic','Noto Sans Cyrillic',sans-serif}.container{padding:28rpx;padding-bottom:140rpx}.card{background:#fff;border-radius:28rpx;padding:28rpx;box-shadow:0 12rpx 32rpx rgba(0,61,122,.08);margin-bottom:24rpx}.btn{height:88rpx;border-radius:44rpx;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:30rpx}.btn-primary{background:linear-gradient(135deg,#003D7A,#008B8B);color:white}.btn-gold{background:#C9A961;color:#fff}.muted{color:#667085}.kazakh-line{height:10rpx;border-radius:10rpx;background:repeating-linear-gradient(45deg,#C9A961 0 12rpx,#008B8B 12rpx 24rpx,#003D7A 24rpx 36rpx);opacity:.9}.section-title{font-size:36rpx;font-weight:800;margin:36rpx 0 20rpx}.tag{display:inline-flex;background:#EAF4F4;color:#008B8B;border-radius:999rpx;padding:10rpx 18rpx;font-size:24rpx;margin-right:10rpx}.input{height:88rpx;background:#F9FAFB;border:2rpx solid #EAECF0;border-radius:22rpx;padding:0 24rpx;font-size:28rpx;margin-bottom:18rpx}.textarea{min-height:150rpx;background:#F9FAFB;border:2rpx solid #EAECF0;border-radius:22rpx;padding:20rpx 24rpx;font-size:28rpx;margin-bottom:18rpx}.ornament{position:absolute;right:-20rpx;top:-20rpx;width:170rpx;height:170rpx;border:4rpx solid rgba(201,169,97,.5);border-radius:36rpx;transform:rotate(45deg)}
button.btn{padding:0;border:0;line-height:88rpx}button.btn::after{border:0}
.rtl{direction:rtl;text-align:right;font-family:'KazakhArabicLight','Apple SD Arabic Light','Noto Sans Arabic Light',-apple-system,sans-serif;font-weight:300}.rtl .hero-title,.rtl .section-title,.rtl .s-name,.rtl .title,.rtl .name{font-weight:300}.rtl .btn{font-size:26rpx}.rtl input,.rtl textarea,.rtl .input,.rtl .textarea{direction:rtl;text-align:right}.rtl .picker{direction:rtl;text-align:right}
.lang-row{justify-content:flex-start!important;flex-direction:row!important}.lang-pill{display:inline-block!important;direction:ltr!important;text-align:left!important;unicode-bidi:plaintext!important;float:none!important}