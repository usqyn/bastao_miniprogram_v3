.hero{position:relative;overflow:hidden;border-radius:34rpx;padding:38rpx 30rpx;background:linear-gradient(135deg,#003D7A 0%,#008B8B 100%);color:white}.lang-pills{display:flex;gap:10rpx;margin:20rpx 0;direction:ltr!important}.lang-pills .lang-pill{font-size:22rpx;padding:10rpx 16rpx;border-radius:999rpx;background:#E8F4FD;color:#003D7A;border:1rpx solid #B8D4E8}.lang-pills .lang-pill.active{background:#C9A961;color:#fff;border-color:#C9A961}.lang{font-size:24rpx;opacity:.85;margin-bottom:34rpx}.hero-title{font-size:46rpx;line-height:1.22;font-weight:900;letter-spacing:1rpx}.hero-sub{font-size:26rpx;opacity:.9;margin:20rpx 0 28rpx}.search-card{background:rgba(255,255,255,.96);border-radius:28rpx;padding:20rpx;box-shadow:0 20rpx 50rpx rgba(0,0,0,.15)}.hero-input{height:86rpx;color:#111;background:#F6F8FB;border-radius:22rpx;padding:0 22rpx;margin-bottom:20rpx}.search-card .btn-gold{margin-bottom:16rpx}.service-grid{display:grid;grid-template-columns:1fr 1fr;gap:20rpx}.service-card{position:relative;background:#fff;border-radius:34rpx;padding:26rpx;box-shadow:0 10rpx 28rpx rgba(0,61,122,.07);border:4rpx solid transparent;background-image:linear-gradient(#fff,#fff),linear-gradient(135deg,#003D7A 0%,#008B8B 100%);background-origin:border-box;background-clip:padding-box,border-box;overflow:hidden}.card-ornament-top{position:absolute;top:0;left:0;right:0;height:6rpx;background:linear-gradient(135deg,#003D7A 0%,#008B8B 100%)}.card-ornament-corner{position:absolute;top:12rpx;right:12rpx;width:24rpx;height:24rpx;border:2rpx solid #C9A961;border-radius:4rpx;opacity:.5}.icon-box{display:inline-flex;align-items:center;justify-content:center;width:72rpx;height:72rpx;background:#E8F4FD;border-radius:16rpx;font-size:36rpx;margin-bottom:16rpx}.s-name{font-weight:800;font-size:29rpx;margin-bottom:8rpx;color:#003D7A}.s-desc{font-size:24rpx;color:#667085;line-height:1.5}.why-row{font-size:28rpx;padding:18rpx 0;border-bottom:1rpx solid #F0F2F5}.why-row:last-child{border-bottom:none}
.lang-pills{display:flex;gap:10rpx;position:relative;z-index:100}.lang-pills .lang-pill{font-size:22rpx;padding:10rpx 16rpx;border-radius:999rpx;background:#E8F4FD;color:#003D7A;border:1rpx solid #B8D4E8}.lang-pills .lang-pill.active{background:#C9A961;color:#fff;border-color:#C9A961}
.lang-row-top{display:flex;gap:10rpx;flex-wrap:wrap;margin-bottom:10rpx;position:absolute;top:28rpx;left:28rpx;z-index:100}.lang-row-top .lang-pill{font-size:22rpx;padding:10rpx 16rpx;border-radius:999rpx;background:rgba(255,255,255,.16);color:#fff;border:1rpx solid rgba(255,255,255,.25)}.lang-row-top .lang-pill.active{background:#C9A961;color:#fff}
.lang-row{display:flex;gap:10rpx;flex-wrap:wrap;margin-bottom:30rpx;position:relative;z-index:2;justify-content:flex-start;flex-direction:row}.lang-pill{font-size:22rpx;padding:10rpx 16rpx;border-radius:999rpx;background:rgba(255,255,255,.16);color:#fff;border:1rpx solid rgba(255,255,255,.25);display:inline-block;direction:ltr;text-align:left}.lang-pill.active{background:#C9A961;color:#fff}.rtl{direction:rtl}.search-card button{border:0}.search-card button::after{border:0}
.ghost{margin-top:14rpx;background:rgba(0,61,122,.08);color:#003D7A}
.hero-swiper{width:100%;height:200rpx;border-radius:20rpx;overflow:hidden;margin-bottom:20rpx;background:#fff}
.banner-img{width:100%;height:100%;object-fit:contain}
