/* 语言切换 */
.lang-pills {
  display: flex;
  gap: 10rpx;
  padding: 20rpx;
  background: #fff;
}

.lang-pills .lang-pill {
  font-size: 22rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #E8F4FD;
  color: #003D7A;
  border: 1rpx solid #B8D4E8;
}

.lang-pills .lang-pill.active {
  background: #C9A961;
  color: #fff;
  border-color: #C9A961;
}

/* 容器 */
.container {
  padding: 0 20rpx 40rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

/* 轮播区域 */
.banner-section {
  position: relative;
  margin: 0 -20rpx;
  background: linear-gradient(180deg, #87CEEB 0%, #E0F6FF 100%);
  padding-bottom: 60rpx;
}

.banner-swiper {
  width: 100%;
  height: 500rpx;
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.banner-bg {
  width: 100%;
  height: 100%;
  opacity: 0.9;
}

.banner-overlay {
  position: absolute;
  top: 60rpx;
  left: 40rpx;
  color: #C41E3A;
}

.banner-brand {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
  letter-spacing: 4rpx;
}

.banner-title {
  font-size: 72rpx;
  font-weight: 900;
  line-height: 1;
  margin-bottom: 10rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.banner-cities {
  font-size: 20rpx;
  color: #666;
  max-width: 400rpx;
  line-height: 1.4;
}

/* 快捷入口卡片 */
.quick-entry-card {
  background: #fff;
  border-radius: 24rpx;
  margin: -60rpx 20rpx 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.rtl .quick-entry-card {
  direction: rtl;
}

.rtl .quick-row {
  flex-direction: row;
}

.rtl .quick-title {
  font-weight: 500;
}

.rtl .quick-desc {
  color: #666;
}

.quick-row {
  display: flex;
  justify-content: space-between;
}

.quick-item {
  text-align: center;
  flex: 1;
  min-width: 0;
}

.quick-item .quick-title {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

.quick-item .quick-desc {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

.quick-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.quick-title .arrow {
  color: #C41E3A;
  margin-left: 8rpx;
}

.rtl .quick-title .arrow {
  margin-left: 0;
  margin-right: 8rpx;
  transform: rotate(180deg);
  display: inline-block;
}

.quick-desc {
  font-size: 24rpx;
  color: #999;
}

.quick-icons {
  display: flex;
  justify-content: space-around;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-box {
  width: 80rpx;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.icon-box.gold {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
}

.icon-text {
  font-size: 24rpx;
  color: #666;
}

/* VIP卡片 */
.vip-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.vip-header {
  margin-bottom: 24rpx;
}

.vip-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.vip-tag {
  background: linear-gradient(90deg, #FFD700 0%, #FFA500 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  margin-left: 12rpx;
}

.vip-stats {
  display: flex;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.vip-privilege {
  display: flex;
  align-items: center;
  background: #FFF8F0;
  border-radius: 16rpx;
  padding: 20rpx;
}

.privilege-title {
  font-size: 24rpx;
  color: #FF9500;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.privilege-desc {
  flex: 1;
  font-size: 24rpx;
  color: #666;
}

.privilege-arrow {
  font-size: 32rpx;
  color: #999;
}

/* 推广横幅 */
.promo-banner {
  display: flex;
  background: linear-gradient(90deg, #E8F4FD 0%, #F0F8FF 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.promo-content {
  flex: 1;
}

.promo-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #003D7A;
  margin-bottom: 8rpx;
}

.promo-subtitle {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.promo-btn {
  display: inline-block;
  background: #333;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

.promo-img {
  width: 160rpx;
  height: 120rpx;
  border-radius: 16rpx;
}

/* 分类标签 */
.category-tabs {
  display: flex;
  background: #fff;
  padding: 24rpx 30rpx;
  margin: 0 -20rpx 20rpx;
  gap: 40rpx;
}

.tab-item {
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #333;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #C41E3A;
  border-radius: 2rpx;
}

/* 服务网格 */
.service-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.service-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 26rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 61, 122, 0.07);
}

.icon-box {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: #E8F4FD;
  border-radius: 16rpx;
  font-size: 36rpx;
  margin-bottom: 16rpx;
}

.s-name {
  font-weight: 700;
  font-size: 28rpx;
  margin-bottom: 8rpx;
  color: #003D7A;
}

.s-desc {
  font-size: 22rpx;
  color: #667085;
  line-height: 1.5;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin: 30rpx 0 20rpx;
}

/* 为什么选择我们 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.kazakh-line {
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #003D7A 0%, #008B8B 50%, #C9A961 100%);
  margin-bottom: 20rpx;
  border-radius: 3rpx;
}

.why-row {
  font-size: 26rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F2F5;
  color: #333;
}

.why-row:last-child {
  border-bottom: none;
}

/* RTL适配 */
.rtl {
  direction: rtl;
}
