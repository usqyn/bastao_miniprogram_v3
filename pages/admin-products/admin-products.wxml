<!-- 管理后台 - 商品管理页面 -->
<view class="admin-page">
  <!-- 顶部操作栏 -->
  <view class="admin-header">
    <view class="header-title">商品管理</view>
    <view class="header-action">
      <view class="add-btn" bindtap="showAddModal">+ 添加商品</view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="搜索商品名称" 
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
    />
    <view class="search-btn" bindtap="handleSearch">搜索</view>
  </view>

  <!-- 商品列表 -->
  <view class="product-list">
    <view class="product-item" wx:for="{{products}}" wx:key="id">
      <image class="product-img" src="{{item.image}}" mode="aspectFill" />
      <view class="product-info">
        <view class="product-name">{{item.name}}</view>
        <view class="product-price">¥{{item.price}}</view>
        <view class="product-category">{{categories[item.category]}}</view>
      </view>
      <view class="product-actions">
        <view class="action-btn edit" bindtap="editProduct" data-item="{{item}}">编辑</view>
        <view class="action-btn delete" bindtap="deleteProduct" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{products.length === 0}}">
    <view class="empty-icon">📦</view>
    <view class="empty-text">暂无商品</view>
  </view>
</view>

<!-- 添加/编辑商品弹窗 -->
<view class="modal {{showModal ? 'show' : ''}}" wx:if="{{showModal}}">
  <view class="modal-mask" bindtap="hideModal"></view>
  <view class="modal-content">
    <view class="modal-header">
      <view class="modal-title">{{isEdit ? '编辑商品' : '添加商品'}}</view>
      <view class="modal-close" bindtap="hideModal">✕</view>
    </view>
    
    <scroll-view class="modal-body" scroll-y>
      <view class="form-item">
        <view class="form-label">商品名称</view>
        <input class="form-input" placeholder="请输入商品名称" value="{{form.name}}" bindinput="onFormInput" data-field="name" />
      </view>
      
      <view class="form-item">
        <view class="form-label">卖点标题</view>
        <input class="form-input" placeholder="例如：【品牌保护首选】" value="{{form.slogan}}" bindinput="onFormInput" data-field="slogan" />
      </view>
      
      <view class="form-item">
        <view class="form-label">价格</view>
        <input class="form-input" type="digit" placeholder="请输入价格" value="{{form.price}}" bindinput="onFormInput" data-field="price" />
      </view>
      
      <view class="form-item">
        <view class="form-label">原价</view>
        <input class="form-input" type="digit" placeholder="请输入原价（选填）" value="{{form.originalPrice}}" bindinput="onFormInput" data-field="originalPrice" />
      </view>
      
      <view class="form-item">
        <view class="form-label">分类</view>
        <picker mode="selector" range="{{categories}}" range-key="name" value="{{form.category}}" bindchange="onCategoryChange">
          <view class="form-picker">{{categories[form.category] || '请选择分类'}}</view>
        </picker>
      </view>
      
      <view class="form-item">
        <view class="form-label">规格</view>
        <input class="form-input" placeholder="例如：含查询+分类+递交全流程" value="{{form.spec}}" bindinput="onFormInput" data-field="spec" />
      </view>
      
      <view class="form-item">
        <view class="form-label">角标</view>
        <input class="form-input" placeholder="例如：HOT、新品、特价" value="{{form.badge}}" bindinput="onFormInput" data-field="badge" />
      </view>
      
      <view class="form-item">
        <view class="form-label">促销信息</view>
        <input class="form-input" placeholder="例如：限时优惠 立减¥200" value="{{form.promo}}" bindinput="onFormInput" data-field="promo" />
      </view>
    </scroll-view>
    
    <view class="modal-footer">
      <view class="btn-cancel" bindtap="hideModal">取消</view>
      <view class="btn-confirm" bindtap="saveProduct">保存</view>
    </view>
  </view>
</view>
