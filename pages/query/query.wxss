.title{font-size:42rpx;font-weight:900;color:#003D7A;margin:22rpx 0 12rpx}.picker{display:flex;align-items:center;color:#344054}.tips{line-height:2;color:#344054}.tips-title{font-weight:800;color:#003D7A;font-size:31rpx;margin-bottom:10rpx}
