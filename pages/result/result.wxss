.result-card{border-radius:34rpx;padding:44rpx 30rpx;margin-bottom:24rpx;color:white;text-align:center;box-shadow:0 16rpx 42rpx rgba(0,0,0,.12)}.available{background:linear-gradient(135deg,#008B8B,#0EA66B)}.registered{background:linear-gradient(135deg,#B42318,#F79009)}.unknown{background:linear-gradient(135deg,#003D7A,#C9A961)}.status-icon{font-size:70rpx}.r-title{font-size:42rpx;font-weight:900;margin:10rpx 0}.r-sub{opacity:.9}.risk{margin-top:22rpx;background:rgba(255,255,255,.18);border-radius:20rpx;padding:18rpx;font-weight:700}.mini{margin-top:0}.advice{font-size:28rpx;line-height:1.75;color:#344054;margin-bottom:24rpx}.course-title{font-size:32rpx;font-weight:900;color:#003D7A}.small-btn{margin-top:18rpx;border:2rpx solid #C9A961;color:#C9A961;border-radius:40rpx;height:72rpx;display:flex;align-items:center;justify-content:center;font-weight:700}
.lang-row{display:flex;gap:10rpx;flex-wrap:wrap;margin-bottom:20rpx;justify-content:flex-start;flex-direction:row}.lang-pill{font-size:22rpx;padding:10rpx 16rpx;border-radius:999rpx;background:#fff;color:#003D7A;border:1rpx solid #D0D5DD;display:inline-block;direction:ltr;text-align:left}.lang-pill.active{background:#C9A961;color:#fff;border-color:#C9A961}button.btn{border:0}button.btn::after{border:0}
