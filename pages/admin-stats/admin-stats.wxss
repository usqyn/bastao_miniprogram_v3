/* 管理后台样式 */
.admin-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 顶部导航 */
.admin-header {
  background: linear-gradient(135deg, #003D7A 0%, #0056A8 100%);
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.welcome {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.logout-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

/* 快捷入口 */
.quick-nav {
  display: flex;
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.nav-icon {
  font-size: 48rpx;
}

.nav-text {
  font-size: 24rpx;
  color: #333;
}

/* 统计卡片 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 15rpx;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.stat-icon.blue { background: #E3F2FD; }
.stat-icon.red { background: #FFEBEE; }
.stat-icon.orange { background: #FFF3E0; }
.stat-icon.green { background: #E8F5E9; }

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 区块 */
.section {
  background: #fff;
  margin: 0 15rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 今日概览 */
.today-grid {
  display: flex;
  gap: 20rpx;
}

.today-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.today-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #C41E3A;
  margin-bottom: 8rpx;
}

.today-label {
  font-size: 22rpx;
  color: #666;
}

/* 最新订单 */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #F9F9F9;
  border-radius: 12rpx;
}

.order-no {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.order-time {
  font-size: 22rpx;
  color: #999;
}

.order-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #C41E3A;
  text-align: right;
  margin-bottom: 6rpx;
}

.order-status {
  font-size: 22rpx;
  text-align: right;
}

.status-pending { color: #FF9800; }
.status-paid { color: #2196F3; }
.status-shipped { color: #4CAF50; }
.status-completed { color: #999; }
