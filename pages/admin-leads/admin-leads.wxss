/* 后台管理页面 */

/* ===== 登录页面 ===== */
.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #003D7A 0%, #0056A8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.login-card {
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.login-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.login-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #003D7A;
  margin-bottom: 10rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: #999;
}

.login-form {
  width: 100%;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 90rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.login-btn {
  width: 100%;
  height: 90rpx;
  background: #C41E3A;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn.loading {
  opacity: 0.7;
}

.login-tips {
  text-align: center;
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #999;
}

/* ===== 线索列表页面 ===== */
.admin-page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 头部 */
.admin-header {
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.header-btn {
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.header-btn.primary {
  background: #333;
  color: #fff;
}

.header-btn.secondary {
  background: #F5F5F5;
  color: #666;
}

/* 统计卡片 */
.stats-row {
  display: flex;
  padding: 20rpx;
  gap: 16rpx;
  background: #fff;
}

.stat-card {
  flex: 1;
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #C41E3A;
  margin-bottom: 8rpx;
}

.stat-num.blue { color: #1976D2; }
.stat-num.green { color: #4CAF50; }
.stat-num.gray { color: #999; }

.stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-item.active {
  background: #E8F4FD;
  color: #003D7A;
  font-weight: 600;
}

/* 表格 */
.table-container {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.table-header {
  display: flex;
  background: #F5F5F5;
  padding: 20rpx 16rpx;
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
}

.table-row {
  display: flex;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
  font-size: 24rpx;
  color: #333;
  align-items: center;
}

.table-row:last-child {
  border-bottom: none;
}

.table-col {
  flex-shrink: 0;
  padding: 0 8rpx;
}

.col-check { width: 50rpx; }
.col-id { width: 50rpx; text-align: center; }
.col-time { width: 160rpx; }
.col-name { width: 120rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.col-phone { width: 160rpx; }
.col-type { width: 120rpx; }
.col-status { width: 100rpx; }
.col-action { width: 60rpx; text-align: center; }

/* 复选框 */
.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #D0D5DD;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: transparent;
}

.checkbox.checked {
  background: #003D7A;
  border-color: #003D7A;
  color: #fff;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.status-pending {
  background: #E3F2FD;
  color: #1976D2;
}

.status-contacted {
  background: #FFF8E1;
  color: #F57C00;
}

.status-closed {
  background: #F5F5F5;
  color: #999;
}

/* 操作按钮 */
.action-btn {
  padding: 8rpx 12rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.action-btn.delete {
  background: #FFEBEE;
  color: #C41E3A;
}

/* 空状态 */
.empty-state {
  padding: 80rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 分页 */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  gap: 20rpx;
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.page-btn {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.page-btn.active {
  background: #003D7A;
  color: #fff;
}

.page-info {
  font-size: 24rpx;
  color: #999;
}
