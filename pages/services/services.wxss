/* 商城页面 */
.mall-page {
  padding-bottom: 180rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

/* 顶部品牌区 */
.mall-header {
  background: #fff;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 16rpx;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.header-left {
  flex: 1;
}

.header-right {
  padding-left: 20rpx;
}

.mall-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #003D7A;
  margin: 16rpx 0 8rpx;
}

.mall-subtitle {
  font-size: 24rpx;
  color: #667085;
}

/* 顶部购物车图标 */
.cart-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background: #FFF0F0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon-wrap .cart-icon {
  font-size: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #C41E3A;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* 分类标签栏 */
.category-bar {
  background: #fff;
  white-space: nowrap;
  padding: 0 28rpx;
  margin-bottom: 16rpx;
}

.category-list {
  display: inline-flex;
  gap: 0;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  color: #333;
  position: relative;
  white-space: nowrap;
}

.category-item.active {
  color: #C41E3A;
  font-weight: 700;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #C41E3A;
}

/* 商品双列网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx;
  gap: 16rpx;
}

/* 商品卡片 */
.product-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 商品图片区 */
.product-img-wrap {
  position: relative;
  width: 100%;
  height: 340rpx;
  overflow: hidden;
}

.product-img {
  width: 100%;
  height: 100%;
}

/* 角标 */
.product-badge {
  position: absolute;
  top: 0;
  left: 0;
  background: #C41E3A;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 0 0 16rpx 0;
  z-index: 2;
}

/* 促销条 */
.product-promo {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(90deg, #C41E3A, #E8384F);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  text-align: center;
  padding: 8rpx 0;
  z-index: 2;
}

/* 商品信息区 */
.product-info {
  padding: 16rpx 20rpx 20rpx;
}

/* 卖点标题 */
.product-slogan {
  font-size: 26rpx;
  font-weight: 800;
  color: #1A1A1A;
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 商品名称 */
.product-name {
  font-size: 24rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 6rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 规格 */
.product-spec {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 10rpx;
}

/* 商品标签 */
.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.product-tag {
  display: inline-flex;
  background: #FFF0F0;
  color: #C41E3A;
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
}

/* 价格区 */
.product-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 800;
  color: #C41E3A;
}

.price-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #C41E3A;
  line-height: 1;
}

.price-original {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 8rpx;
}

/* 加入购物车按钮 */
.product-cart {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #C41E3A;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-cart .cart-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
}

/* 底部购物车栏 */
.mall-footer {
  position: fixed;
  bottom: 100rpx;
  left: 20rpx;
  right: 20rpx;
  background: #fff;
  border-radius: 50rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
}

.footer-cart {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.footer-cart-icon {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background: #C41E3A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -30rpx;
}

.footer-cart-icon text {
  font-size: 36rpx;
}

.footer-cart-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #fff;
  color: #C41E3A;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.footer-cart-total {
  font-size: 26rpx;
  color: #333;
}

.footer-cart-total .total-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #C41E3A;
}

.footer-checkout {
  background: #C41E3A;
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 语言切换 */
.lang-pills {
  display: flex;
  gap: 10rpx;
  margin-bottom: 20rpx;
  direction: ltr !important;
}

.lang-pills .lang-pill {
  font-size: 22rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #003D7A;
  border: 1rpx solid #D0D5DD;
}

.lang-pills .lang-pill.active {
  background: #C9A961;
  color: #fff;
  border-color: #C9A961;
}

/* RTL 适配 */
.rtl .mall-title,
.rtl .product-slogan,
.rtl .product-name {
  text-align: right;
}

.rtl .product-tags {
  justify-content: flex-end;
}

.rtl .product-price-row {
  flex-direction: row-reverse;
}

.rtl .product-badge {
  left: auto;
  right: 0;
  border-radius: 0 0 0 16rpx;
}
