.title{font-size:40rpx;font-weight:900;color:#003D7A;margin:22rpx 0 10rpx}.row{display:flex;gap:22rpx;align-items:flex-start}.icon{font-size:48rpx}.name{font-size:32rpx;font-weight:900;color:#003D7A;margin-bottom:8rpx}.tags{margin:22rpx 0}.service .btn{height:78rpx}
.lang-pills{display:flex;gap:10rpx;margin-bottom:20rpx;direction:ltr!important}.lang-pills .lang-pill{font-size:22rpx;padding:10rpx 16rpx;border-radius:999rpx;background:#fff;color:#003D7A;border:1rpx solid #D0D5DD}.lang-pills .lang-pill.active{background:#C9A961;color:#fff;border-color:#C9A961}
button.btn{border:0}button.btn::after{border:0}
