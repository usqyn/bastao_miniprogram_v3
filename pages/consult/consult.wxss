.title{font-size:40rpx;font-weight:900;color:#003D7A;margin:22rpx 0 10rpx}.picker{display:flex;align-items:center;color:#344054}.contact{line-height:2;color:#344054;font-size:28rpx}.qr-section{text-align:center;padding:20rpx 0}.qrcode{width:240rpx;height:240rpx;border-radius:16rpx;margin-bottom:16rpx}.qr-text{font-size:26rpx;color:#667085}
.lang-pills{display:flex;gap:10rpx;margin-bottom:20rpx}.lang-pills .lang-pill{font-size:22rpx;padding:10rpx 16rpx;border-radius:999rpx;background:#fff;color:#003D7A;border:1rpx solid #D0D5DD}.lang-pills .lang-pill.active{background:#C9A961;color:#fff;border-color:#C9A961}
button.btn{border:0}button.btn::after{border:0}