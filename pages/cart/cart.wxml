<!-- 购物车页面 -->
<view class="cart-page">

  <!-- 语言切换 -->
  <view class="lang-pills">
    <view class="lang-pill {{lang==='zh'?'active':''}}" data-lang="zh" bindtap="changeLang">中文</view>
    <view class="lang-pill {{lang==='kkArab'?'active':''}}" data-lang="kkArab" bindtap="changeLang">قازاقشا</view>
    <view class="lang-pill {{lang==='kkCyrl'?'active':''}}" data-lang="kkCyrl" bindtap="changeLang">Қазақша</view>
  </view>

  <!-- 空购物车 -->
  <view class="empty-cart" wx:if="{{cartItems.length === 0}}">
    <view class="empty-icon">🛒</view>
    <view class="empty-text">{{t.cartEmpty}}</view>
    <view class="go-shop-btn" bindtap="goShop">{{t.goShop}}</view>
  </view>

  <!-- 购物车列表 -->
  <view class="cart-list" wx:if="{{cartItems.length > 0}}">
    <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
      <view class="item-check" bindtap="toggleSelect" data-id="{{item.id}}">
        <view class="check-box {{item.selected ? 'checked' : ''}}">✓</view>
      </view>
      <image class="item-img" src="{{item.image}}" mode="aspectFill" />
      <view class="item-info">
        <view class="item-name">{{item.name}}</view>
        <view class="item-spec" wx:if="{{item.spec}}">{{item.spec}}</view>
        <view class="item-price-row">
          <view class="item-price">
            <text class="price-symbol">¥</text>
            <text class="price-num">{{item.price}}</text>
          </view>
          <view class="item-qty">
            <view class="qty-btn" bindtap="decreaseQty" data-id="{{item.id}}">-</view>
            <view class="qty-num">{{item.quantity}}</view>
            <view class="qty-btn" bindtap="increaseQty" data-id="{{item.id}}">+</view>
          </view>
        </view>
      </view>
      <view class="item-delete" bindtap="removeItem" data-id="{{item.id}}">✕</view>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="cart-footer" wx:if="{{cartItems.length > 0}}">
    <view class="footer-left">
      <view class="all-check" bindtap="toggleAllSelect">
        <view class="check-box {{allSelected ? 'checked' : ''}}">✓</view>
        <text>{{t.selectAll}}</text>
      </view>
    </view>
    <view class="footer-right">
      <view class="total-price">
        <text>{{t.total}}:</text>
        <text class="price-symbol">¥</text>
        <text class="price-num">{{totalPrice}}</text>
      </view>
      <view class="checkout-btn {{selectedCount === 0 ? 'disabled' : ''}}" bindtap="goCheckout">
        {{t.checkout}}({{selectedCount}})
      </view>
    </view>
  </view>

</view>
